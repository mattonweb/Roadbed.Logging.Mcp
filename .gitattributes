# This prevents corruption and keeps diffs clean.

*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.bmp   binary
*.ico   binary
*.tif   binary
*.tiff  binary
*.webp  binary
*.avif  binary
*.heic  binary

*.zip   binary
*.7z    binary
*.rar   binary
*.tar   binary
*.gz    binary
*.tgz   binary
*.bz2   binary
*.xz    binary

*.exe   binary
*.dll   binary
*.pdb   binary
*.lib   binary
*.so    binary
*.dylib binary
*.msi   binary
*.msix  binary
*.appx  binary
*.appxbundle binary
*.cab   binary
*.iso   binary

*.bin   binary
*.dat   binary
*.pak   binary
*.nupkg binary
*.snupkg binary
*.wasm  binary

*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary

*.mp3   binary
*.mp4   binary
*.mov   binary
*.avi   binary
*.m4a   binary
*.wav   binary

# Design assets
*.psd   binary
*.ai    binary
*.sketch binary
*.fig   binary
*.drawio binary   # Often XML but contains embedded binary data; safest as binary
